# Backend (loaded by FastAPI via app/config.py)
APP_NAME=AgriPulse AI API
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/agripulse
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_MINUTES=1440
JWT_COOKIE_NAME=access_token
CORS_ORIGINS=http://localhost:3000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Frontend (loaded by Next.js at build time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Docker infrastructure defaults (used by docker-compose.yml)
POSTGRES_DB=agripulse
POSTGRES_USER=app
POSTGRES_PASSWORD=app
