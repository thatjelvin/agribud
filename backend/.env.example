APP_NAME=AgriPulse AI API
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/agripulse
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_MINUTES=1440
JWT_COOKIE_NAME=access_token

CORS_ORIGINS=http://localhost:3000

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Yield model: v1-statistical (default) | v0-stub | module:Class
YIELD_MODEL=v1-statistical

# Geospatial provider: mock (default) | open_meteo
GEOSPATIAL_PROVIDER=mock
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# Dev seed: 1 to run app/scripts/seed on startup, 0 to skip
AGRIBUD_SEED=1
